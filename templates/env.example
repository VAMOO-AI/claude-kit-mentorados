# Modelo de variáveis de ambiente — COPIE para .env.local e preencha os valores.
#
# Este arquivo (.env.example) VAI pro git: lista as CHAVES, nunca os valores.
# O .env / .env.local com os valores reais NUNCA vai pro git (está no .gitignore).
#
# Pegue os valores no painel de cada serviço. Nunca cole secret no chat/WhatsApp.

# --- Exemplo Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Exemplo: nunca exponha a service_role no front (sem NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=
